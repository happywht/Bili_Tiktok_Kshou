# B站视频搜索API环境配置

# ============ 应用配置 ============
DEBUG=false

# ============ B站配置 ============
# 获取方式: 浏览器登录B站 → F12 → Application → Cookies → bilibili.com → 复制SESSDATA值
# 注意: 可选，不配置也可以使用搜索功能
BILIBILI_SESSDATA=

# ============ AI总结配置 ============
# 用于视频AI总结功能，获取方式: https://open.bigmodel.cn/usercenter/apikeys
# 注意: 可选，不配置则无法使用AI总结功能
LLM_API_KEY=
LLM_API_BASE=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ============ API配置 ============
API_PREFIX=/api/v1

# ============ CORS配置 ============
# 多个用逗号分隔, * 表示允许所有
CORS_ORIGINS=*
