# 多平台视频搜索API环境配置

# ============ 应用配置 ============
DEBUG=false

# ============ B站配置 ============
# 获取方式: 浏览器登录B站 → F12 → Application → Cookies → bilibili.com → 复制SESSDATA值
BILIBILI_SESSDATA=your_sessdata_here

# ============ MediaCrawler 配置（抖音/小红书共用） ============
# MediaCrawler 通过 Playwright 浏览器自动化实现搜索
# 首次使用需要扫码登录（见下方说明）

# 浏览器无头模式: true=后台运行(已登录后), false=显示窗口(首次登录需要)
MEDIACRAWLER_HEADLESS=true
# 搜索超时时间（秒），浏览器启动较慢建议设大一些
MEDIACRAWLER_TIMEOUT=150

# ============ 抖音配置（通过 MediaCrawler） ============
# 抖音搜索基于 MediaCrawler 浏览器自动化，不需要手动配置 Cookie
# 首次使用: 设置 MEDIACRAWLER_HEADLESS=false → 扫码登录 → 改回 true
DOUYIN_COOKIES=
DOUYIN_TTWID=
DOUYIN_HEADLESS=true

# ============ 小红书配置（通过 MediaCrawler） ============
# 小红书搜索基于 MediaCrawler 浏览器自动化，不需要手动配置 Cookie
# 首次使用: 设置 MEDIACRAWLER_HEADLESS=false → 扫码登录 → 改回 true
XIAOHONGSHU_COOKIES=
XIAOHONGSHU_HEADLESS=true

# ============ API配置 ============
API_PREFIX=/api/v1

# ============ CORS配置 ============
# 多个用逗号分隔, * 表示允许所有
CORS_ORIGINS=*
